# Ansible managed

server {
    server_name voyeur.istic.dev;
    listen 80;
    add_header X-WhyAmI "delta-staging redirect";
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name voyeur.istic.dev;
    server_tokens off;
    root {{ stream_delta_staging_install_dir }}/current/public;

    index index.php;

    charset utf-8;

    location /index.php {
        try_files /not_exists @octane;
    }

    location / {
        try_files $uri $uri/ @octane;
    }

    location = /favicon.ico {
        access_log off; log_not_found off;
    }

    location = /robots.txt {
        access_log off; log_not_found off;
    }

    access_log off;
    error_log /var/log/nginx/voyeur.istic.dev-error.log error;

    error_page 404 /index.php;

    location @octane {
        set $suffix "";

        if ($uri = /index.php) {
            set $suffix ?$query_string;
        }

        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header Scheme $scheme;
        proxy_set_header SERVER_PORT $server_port;
        proxy_set_header REMOTE_ADDR $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_pass http://127.0.0.1:{{ stream_delta_staging_octane_port }}$suffix;
    }
    include /etc/nginx/snippets/errors.conf;
    include /etc/nginx/snippets/ssl/delta_staging_ssl.conf;
    add_header X-WhyAmI delta-staging;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name ws.voyeur.istic.dev;
    server_tokens off;
    root {{ stream_delta_staging_install_dir }}/current/public;

    location / {
        proxy_pass http://localhost:{{ stream_delta_staging_reverb_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
    include /etc/nginx/snippets/ssl/delta_staging_ssl.conf;
}
