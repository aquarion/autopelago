# {{ ansible_managed }}

{% set fla_internal_port = 9000 if fla_ctx.backend == 'fpm' else 8000 %}
{% macro app_environment() %}
      APP_NAME: "{{ fla_ctx.app_name }}"
      APP_ENV: "{{ fla_ctx.app_env }}"
      APP_KEY: "{{ fla_ctx.app_key }}"
      APP_DEBUG: "{{ fla_ctx.app_debug }}"
      APP_URL: "{{ fla_ctx.app_url }}"
      LOG_STACK: "stderr,single"
      MATOMO_AUTH_TOKEN: "{{ laravel_apps_matomo_auth_token }}"
      MATOMO_URL: "{{ laravel_apps_matomo_url }}"
{% if fla_ctx.mysql %}
      DB_CONNECTION: mysql
      DB_HOST: "{{ fla_ctx.mysql.db_host | default('host.docker.internal') }}"
      DB_PORT: "{{ fla_ctx.mysql.db_port | default(3306) }}"
      DB_DATABASE: "{{ fla_ctx.mysql.db_name }}"
      DB_USERNAME: "{{ fla_ctx.mysql.db_user }}"
      DB_PASSWORD: "{{ fla_ctx.mysql.db_password }}"
{% endif %}
{% if fla_ctx.redis %}
      REDIS_HOST: "{{ fla_ctx.redis.host | default('host.docker.internal') }}"
      REDIS_PORT: "{{ fla_ctx.redis.port | default(6379) }}"
      REDIS_USERNAME: "{{ fla_ctx.redis.username }}"
      REDIS_PASSWORD: "{{ fla_ctx.redis.password }}"
      CACHE_STORE: redis
      SESSION_DRIVER: redis
      QUEUE_CONNECTION: redis
{% endif %}
{% if fla_ctx.elasticsearch %}
      ELASTICSEARCH_HOST: "{{ fla_ctx.elasticsearch.host | default('host.docker.internal') }}"
      ELASTICSEARCH_PORT: "{{ fla_ctx.elasticsearch.port | default(9200) }}"
      ELASTICSEARCH_SCHEME: https
      ELASTICSEARCH_USER: "{{ fla_ctx.elasticsearch.username }}"
      ELASTICSEARCH_PASS: "{{ fla_ctx.elasticsearch.password }}"
      ELASTICSEARCH_CACERT: "{{ fla_ctx.elasticsearch.cacert | default('/usr/share/elasticsearch/config/certs/ca/ca.crt') }}"
{% endif %}
{% if fla_ctx.mail %}
      MAIL_MAILER: smtp
      MAIL_HOST: "{{ fla_ctx.mail.host }}"
      MAIL_PORT: "{{ fla_ctx.mail.port | default(587) }}"
      MAIL_USERNAME: "{{ fla_ctx.mail.username }}"
      MAIL_PASSWORD: "{{ fla_ctx.mail.password }}"
      MAIL_FROM_ADDRESS: "{{ fla_ctx.mail.from_address }}"
      MAIL_FROM_NAME: "{{ fla_ctx.mail.from_name }}"
{% endif %}
{% if fla_ctx.otel %}
      OTEL_PHP_AUTOLOAD_ENABLED: "true"
      OTEL_SERVICE_NAME: "{{ fla_ctx.name }}"
      OTEL_RESOURCE_ATTRIBUTES: "service.version={{ fla_ctx.image_tag }},service.environment={{ fla_ctx.app_env }},service.name={{ fla_ctx.app_name }},service.revision={{ fla_ctx.image_tag }},service.branch=main"
      OTEL_TRACES_EXPORTER: "otlp"
      OTEL_METRICS_EXPORTER: "otlp"
      OTEL_LOGS_EXPORTER: "otlp"
      OTEL_EXPORTER_OTLP_PROTOCOL: "grpc"
      OTEL_EXPORTER_OTLP_ENDPOINT: "https://otel.svc.istic.systems:4317"
      OTEL_PROPAGATORS: "baggage,tracecontext"
{% endif %}
{% if fla_ctx.additional_env %}
{% for key, value in fla_ctx.additional_env.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% endmacro %}
{% macro app_volumes() %}
      - storage:{{ fla_ctx.workdir }}/storage
{% for file in fla_ctx.additional_files %}
      - {{ docker_root }}/{{ fla_ctx.name }}/secrets/{{ file.dest }}:{{ fla_ctx.workdir }}/storage/app/{{ file.dest }}:ro
{% endfor %}
{% for vol in fla_ctx.additional_volumes %}
{% if vol.src is defined %}
      - {{ vol.src }}:{{ vol.dest }}
{% else %}
      - {{ vol.name }}:{{ vol.dest }}
{% endif %}
{% endfor %}
{% endmacro %}
name: {{ fla_ctx.name }}
services:
  app:
    image: "{{ fla_ctx.image }}:{{ fla_ctx.image_tag }}"
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ fla_ctx.port }}:{{ fla_internal_port }}"
{% if fla_ctx.healthcheck_path %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ fla_internal_port }}/{{ fla_ctx.healthcheck_path }}"]
      interval: 30s
      timeout: 10s
      retries: 5
{% endif %}
    environment:
{{ app_environment() }}
    volumes:
{{ app_volumes() }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - firth_services
    logging:
      driver: journald
      options:
        tag: "$${.Name}/$${.ID}"

{% if fla_ctx.worker %}
  worker:
    image: "{{ fla_ctx.image }}:{{ fla_ctx.image_tag }}"
    restart: unless-stopped
    command: ["php", "artisan", "{{ fla_ctx.worker_command }}"]
    depends_on:
      - app
    environment:
{{ app_environment() }}
    volumes:
{{ app_volumes() }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - firth_services
    logging:
      driver: journald
      options:
        tag: "$${.Name}/$${.ID}"

{% endif %}
{% if fla_ctx.scheduler %}
  scheduler:
    image: "{{ fla_ctx.image }}:{{ fla_ctx.image_tag }}"
    restart: unless-stopped
    command: ["php", "artisan", "schedule:work"]
    depends_on:
      - app
    environment:
{{ app_environment() }}
    volumes:
{{ app_volumes() }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - firth_services
    logging:
      driver: journald
      options:
        tag: "$${.Name}/$${.ID}"

{% endif %}
volumes:
  storage:

{% for vol in fla_ctx.additional_volumes %}
{% if vol.name is defined %}
  {{ vol.name }}:
{% if vol.external | default(false) %}
    external: true
    name: {{ vol.name }}
{% endif %}
{% endif %}
{% endfor %}
networks:
  firth_services:
    external: true
    name: "{{ firth_services_docker_network }}"
