
[program:octane_staging]
command=php {{ stream_delta_staging_install_dir }}/current/artisan octane:start --port={{ stream_delta_staging_octane_port }}
user=stream-delta
autostart=true
autorestart=true
stdout_logfile={{ stream_delta_staging_install_dir }}/current/storage/logs/octane_stdout.log
stderr_logfile={{ stream_delta_staging_install_dir }}/current/storage/logs/octane_stderr.log


[program:reverb_staging]
command=php {{ stream_delta_staging_install_dir }}/current/artisan reverb:start --host="127.0.0.1" --port={{ stream_delta_staging_reverb_port }}
autostart=true
autorestart=true
user=stream-delta
redirect_stderr=true
stdout_logfile={{ stream_delta_staging_install_dir }}/current/storage/logs/reverb_stdout.log


