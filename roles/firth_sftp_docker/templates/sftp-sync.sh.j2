#!/bin/bash
# {{ ansible_managed }}
set -euo pipefail

DEFAULTS_FILE="/etc/sftp-sync.cnf"
USERS_CONF="{{ docker_root }}/sftp/etc/users.conf"
SFTP_DIR="{{ docker_root }}/sftp"
HOME_DIR="{{ docker_root }}/sftp/home"

mysql() {
    command mysql --defaults-file="$DEFAULTS_FILE" "$@"
}

dirty=$(mysql -sNe "SELECT dirty FROM sftp_sync WHERE id = 1;")

if [[ "$dirty" != "1" ]]; then
    exit 0
fi

# Write users.conf
mysql -sNe "SELECT CONCAT(username, ':', password, ':e:', uid, ':', gid) FROM sftp_users;" \
    > "$USERS_CONF"

# Sync authorized_keys for each user
while IFS=$'\t' read -r username uid public_key; do
    ssh_dir="$HOME_DIR/$username/.ssh"
    auth_keys="$ssh_dir/authorized_keys"

    if [[ -n "$public_key" ]]; then
        mkdir -p "$ssh_dir"
        echo "$public_key" > "$auth_keys"
        chown -R "$uid:$uid" "$ssh_dir"
        chmod 700 "$ssh_dir"
        chmod 600 "$auth_keys"
    else
        rm -f "$auth_keys"
    fi
done < <(mysql -sNe "SELECT username, uid, COALESCE(public_key, '') FROM sftp_users;")

# Create any new users in the running container (existing users are skipped)
while IFS= read -r line; do
    docker compose -f "$SFTP_DIR/docker-compose.yml" exec -T sftp \
        /usr/local/bin/create-sftp-user "$line" || true
done < "$USERS_CONF"

# Update passwords for all users (handles existing users that were skipped above)
mysql -sNe "SELECT CONCAT(username, ':', password) FROM sftp_users;" | \
    docker compose -f "$SFTP_DIR/docker-compose.yml" exec -T sftp chpasswd -e

mysql -e "UPDATE sftp_sync SET dirty = 0, last_synced_at = NOW() WHERE id = 1;"
